PORT=5000
DB_HOST=localhost
DB_USER=root
DB_PASS=
DB_NAME=Pothole
JWT_SECRET=your_jwt_secret_here

# SMTP settings for nodemailer (use Gmail app password or other SMTP creds)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
# set to true if using SSL (usually 465)
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=your-email@gmail.com
# optional admin email to receive complaint copies
ADMIN_EMAIL=admin@example.com
